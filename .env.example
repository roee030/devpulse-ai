# .env.example — copy to .env.local and fill in values
# ─────────────────────────────────────────────────────

# ── Firebase (free Spark plan) ────────────────────────────────────────────────
# Get from: Firebase Console → Project settings → Your apps → SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Data provider ─────────────────────────────────────────────────────────────
# "mock"  → uses local mock data (no Firebase needed, good for dev/demo)
# "firebase" → reads from Firestore (requires credentials above)
VITE_DATA_PROVIDER=mock

# ── Unified.to (Jira/Linear/GitHub/Slack integration gateway) ─────────────────
# Get from: app.unified.to → Workspace → API Keys
VITE_UNIFIED_API_KEY=
VITE_UNIFIED_WORKSPACE_ID=

# Connection IDs — created in Unified.to per integration
VITE_UNIFIED_JIRA_CONNECTION_ID=
VITE_UNIFIED_LINEAR_CONNECTION_ID=
VITE_UNIFIED_MONDAY_CONNECTION_ID=
VITE_UNIFIED_GITHUB_CONNECTION_ID=
VITE_UNIFIED_SLACK_CONNECTION_ID=
VITE_UNIFIED_TEAMS_CONNECTION_ID=

# ── Agent config (optional — agent auto-reads VITE_FIREBASE_* above) ──────────
# Override workspace ID for AI effort events (defaults to "devpulse")
DEVPULSE_WORKSPACE_ID=devpulse
